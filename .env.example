# ==============================================================================
# HIPForge Environment Variables Template (.env.example)
# ==============================================================================
# Copy this file to '.env' and fill in the values for your environment.
# Make sure no sensitive keys are checked into source control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Redis Service Configuration
# ------------------------------------------------------------------------------
# Connection string for the Redis broker and shared memory store.
# Used by both backend and worker services.
# Format: redis://[host]:[port] or redis://[user]:[password]@[host]:[port]/[db]
REDIS_URL=redis://redis:6379

# ------------------------------------------------------------------------------
# Backend Service Configuration
# ------------------------------------------------------------------------------
# Host path/mount directory for storing isolated workspace files, logs, and reports.
WORKSPACE_PATH=/app/workspace

# Maximum size limit for uploaded files / workspaces (e.g. 100MB).
WORKSPACE_SIZE_LIMIT=100MB

# Default compilation repair attempt budget per migration job.
DEFAULT_RETRY_BUDGET=5

# Verbosity level of logging. Supported values: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# Frontend Service Configuration
# ------------------------------------------------------------------------------
# Publicly accessible URL of the FastAPI backend.
# The frontend uses this to make REST API requests and establish WebSocket connections.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ------------------------------------------------------------------------------
# AI Infrastructure Configuration (Fireworks AI)
# ------------------------------------------------------------------------------
# Fireworks AI API key. Required when USE_MOCK_AI=false.
# Get a key from the Fireworks AI developer platform.
FIREWORKS_API_KEY=your_fireworks_api_key

# ------------------------------------------------------------------------------
# Pre-Hackathon / Mock Development Configuration
# ------------------------------------------------------------------------------
# Toggle mock Fireworks AI clients.
# Set to 'true' in pre-hackathon mode (runs locally without Fireworks credits/keys).
# Set to 'false' in hackathon mode to connect to the live Fireworks API.
USE_MOCK_AI=true

# Toggle mock compiler (hipify-clang / hipcc) runners.
# Set to 'true' in pre-hackathon mode (no local ROCm installation required).
# Set to 'false' in hackathon mode to execute compiler commands locally or in the container.
USE_MOCK_COMPILER=true

# ------------------------------------------------------------------------------
# GPU Configuration (ROCm GPU Pinning)
# ------------------------------------------------------------------------------
# Target GPU device IDs for pinning migration worker compilation and validation workloads.
# Multiple parallel worker instances can be pinned to specific devices (e.g., "0" or "0,1")
# to prevent memory interference on multi-GPU hosts.
HIP_VISIBLE_DEVICES=0
